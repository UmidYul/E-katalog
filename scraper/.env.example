ENVIRONMENT=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/scraper
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
DEFAULT_TIMEOUT_SECONDS=20
REQUEST_CONCURRENCY=20
MAX_RETRIES=5
CRAWL_INTERVAL_MINUTES=360
PLAYWRIGHT_HEADLESS=true
EXAMPLE_STORE_BASE_URL=https://example-store.uz
EXAMPLE_STORE_CATEGORY_PATHS=["/phones","/laptops"]
PROXIES=[]
USER_AGENTS=["Mozilla/5.0 (Windows NT 10.0; Win64; x64)","Mozilla/5.0 (X11; Linux x86_64)"]
