<%- include('partials/header', { title: 'Сравнение смартфонов' }) %>

<section>
  <h1>Сравнение смартфонов</h1>
  <p>Лимит MVP: до <%= limit %> устройств за один раз.</p>

  <form class="filters" action="/compare" method="GET">
    <label for="items">Slug моделей через запятую:</label>
    <input id="items" name="items" value="<%= selected.join(',') %>" placeholder="apple-iphone-15-pro,samsung-galaxy-s24" />
    <button class="btn" type="submit">Сравнить</button>
  </form>

  <details>
    <summary>Доступные модели</summary>
    <ul>
      <% allPhones.forEach(phone => { %>
        <li><code><%= phone.slug %></code> — <%= phone.brand %> <%= phone.model %></li>
      <% }) %>
    </ul>
  </details>

  <% if (compared.length < 2) { %>
    <p class="muted">Добавьте минимум 2 модели для полноценного сравнения.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Параметр</th>
          <% compared.forEach(phone => { %>
            <th><%= phone.brand %> <%= phone.model %></th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Минимальная цена</td>
          <% compared.forEach(phone => { %><td><strong><%= phone.minPriceText %></strong></td><% }) %>
        </tr>
        <tr>
          <td>Экран</td>
          <% compared.forEach(phone => { %><td><%= phone.specs.display %></td><% }) %>
        </tr>
        <tr>
          <td>Процессор</td>
          <% compared.forEach(phone => { %><td><%= phone.specs.chipset %></td><% }) %>
        </tr>
        <tr>
          <td>Камера</td>
          <% compared.forEach(phone => { %><td><%= phone.specs.camera %></td><% }) %>
        </tr>
        <tr>
          <td>Батарея</td>
          <% compared.forEach(phone => { %><td><%= phone.specs.battery %></td><% }) %>
        </tr>
      </tbody>
    </table>
  <% } %>
</section>

<%- include('partials/footer') %>
