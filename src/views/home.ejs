<%- include('partials/header', { title: 'Главная' }) %>

<section class="hero">
  <h1>Сравнение смартфонов и цен в магазинах Узбекистана</h1>
  <p>Минималистичный MVP: каталог устройств, офферы магазинов, сравнение характеристик и переход к покупке.</p>
  <div class="hero-actions">
    <a class="btn" href="/catalog">Открыть каталог</a>
    <a class="btn btn-light" href="/compare">Сравнить модели</a>
  </div>
</section>

<section>
  <h2>Лучшие предложения сегодня</h2>
  <div class="grid">
    <% topDeals.forEach(phone => { %>
      <article class="card">
        <img src="<%= phone.image %>" alt="<%= phone.model %>" />
        <h3><%= phone.brand %> <%= phone.model %></h3>
        <p>от <strong><%= phone.minPriceText %></strong> • <%= phone.offersCount %> магазинов</p>
        <a href="/phone/<%= phone.slug %>">Открыть карточку</a>
      </article>
    <% }) %>
  </div>
</section>

<section class="stats">
  <div><strong><%= totalModels %></strong><span>моделей в каталоге</span></div>
  <div><strong><%= brands.length %></strong><span>брендов</span></div>
  <div><strong>4</strong><span>модели в сравнении (лимит MVP)</span></div>
</section>

<%- include('partials/footer') %>
