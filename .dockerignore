# VCS and local metadata
.git
.gitignore

# Python caches
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache
.mypy_cache

# Node caches
**/node_modules
**/.next
**/.nuxt

# Virtual envs
.venv
venv

# OS/editor
.DS_Store
.vscode
.idea

# Runtime artifacts
*.log
*.tmp
*.swp

# Large/generated data
infra/monitoring/grafana

# Keep required project sources for Dockerfiles
!requirements.txt
!services/**
!shared/**
!migrations/**
!scripts/**
!frontend/**
!infra/nginx/**
!infra/postgres/**

# Never include frontend local build artifacts after re-include rules above.
frontend/node_modules
frontend/.next
frontend/.nuxt
frontend/.turbo
frontend/coverage
frontend/*.tsbuildinfo
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*
frontend/.env
frontend/.env.local
frontend/.env.*.local
